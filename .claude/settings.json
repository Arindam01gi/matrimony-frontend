{
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "MultiEdit",
      "Write",
      "Bash(pnpm:*)",
      "Bash(pnpx:*)",
      "Bash(node:*)",
      "Bash(git:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(tsc:*)",
      "Bash(next:*)"
    ],
    "deny": ["Bash(curl:*)", "Bash(wget:*)", "Bash(rm -rf:*)"],
    "defaultMode": "acceptEdits"
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "60000",
    "BASH_MAX_OUTPUT_LENGTH": "20000",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "NODE_ENV": "development"
  },
  "includeCoAuthoredBy": true,
  "cleanupPeriodDays": 30,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs');let s='';process.stdin.on('data',d=>s+=d);process.stdin.on('end',()=>{try{const j=JSON.parse(s||'{}');const c=j.tool_input?.command||'';const d=j.tool_input?.description||'No description';fs.mkdirSync(process.env.HOME+'/.claude',{recursive:true});fs.appendFileSync(process.env.HOME+'/.claude/bash-command-log.txt',c+' - '+d+'\\n')}catch{}})\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let s='';process.stdin.on('data',d=>s+=d);process.stdin.on('end',()=>{try{const j=JSON.parse(s||'{}');const p=j.tool_input?.file_path||'';if(/\\.(js|jsx|ts|tsx)$/.test(p)){const txt=require('fs').existsSync(p)?require('fs').readFileSync(p,'utf8'):'';if(/console\\.log\\s*\\(/.test(txt)){console.error('console.log is blocked in JS/TS production files: '+p);process.exit(2)}}}catch{}})\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let s='';process.stdin.on('data',d=>s+=d);process.stdin.on('end',()=>{try{const j=JSON.parse(s||'{}');const p=j.tool_input?.file_path||'';if(p.endsWith('package.json')){require('child_process').spawnSync('pnpm',['audit'],{stdio:'inherit',shell:true})}}catch{}})\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let s='';process.stdin.on('data',d=>s+=d);process.stdin.on('end',()=>{try{const j=JSON.parse(s||'{}');const p=j.tool_input?.file_path||'';if(/\\.(js|jsx|ts|tsx|json|css|md|yml|yaml)$/.test(p)){require('child_process').spawnSync('pnpm',['exec','prettier','--write',p],{stdio:'inherit',shell:true})}}catch{}})\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let s='';process.stdin.on('data',d=>s+=d);process.stdin.on('end',()=>{try{const j=JSON.parse(s||'{}');const p=j.tool_input?.file_path||'';if(/\\.(ts|tsx)$/.test(p)){require('child_process').spawnSync('pnpm',['exec','tsc','--noEmit'],{stdio:'inherit',shell:true})}}catch{}})\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let s='';process.stdin.on('data',d=>s+=d);process.stdin.on('end',()=>{try{const j=JSON.parse(s||'{}');const p=j.tool_input?.file_path||'';if(/\\.(js|jsx|ts|tsx)$/.test(p)){require('child_process').spawnSync('pnpm',['lint'],{stdio:'inherit',shell:true})}}catch{}})\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let s='';process.stdin.on('data',d=>s+=d);process.stdin.on('end',()=>{try{const j=JSON.parse(s||'{}');const p=j.tool_input?.file_path||'';if(p.endsWith('package.json')){require('child_process').spawnSync('pnpm',['audit'],{stdio:'inherit',shell:true})}}catch{}})\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs');fs.mkdirSync(process.env.HOME+'/.claude',{recursive:true});fs.appendFileSync(process.env.HOME+'/.claude/notifications.log','Agent notification: '+new Date().toISOString()+'\\n')\""
          }
        ]
      }
    ],
    "Stop": []
  }
}
